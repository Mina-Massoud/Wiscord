{
  "name": "wiscord-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,json}\" \"tests/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:up": "docker compose up -d mongo",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f mongo",
    "db:seed": "tsx src/db/seed.ts",
    "db:seed:loadtest": "tsx src/db/seed-quiz-loadtest.ts",
    "quiz:loadtest": "tsx src/db/run-loadtest.ts",
    "db:seed:whiteboard-loadtest": "tsx src/db/seed-whiteboard-loadtest.ts",
    "whiteboard:loadtest": "tsx src/db/run-whiteboard-loadtest.ts",
    "db:seed:notes-loadtest": "tsx src/db/seed-notes-loadtest.ts",
    "notes:loadtest": "tsx src/db/run-notes-loadtest.ts",
    "storage:login": "tsx scripts/telegram-session-setup.ts"
  },
  "dependencies": {
    "@google/genai": "^1.52.0",
    "@hocuspocus/extension-database": "^4.0.0",
    "@hocuspocus/provider": "^4.0.0",
    "@hocuspocus/server": "^4.0.0",
    "@mozilla/readability": "^0.6.0",
    "@tldraw/sync-core": "^5.0.0",
    "@tldraw/tlschema": "^5.0.0",
    "cookie": "^1.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "input": "^1.0.1",
    "jose": "^6.2.3",
    "jsdom": "^29.1.1",
    "livekit-server-sdk": "^2.15.3",
    "mongoose": "^9.6.2",
    "nanoid": "^5.0.9",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "prosemirror-markdown": "^1.13.4",
    "prosemirror-model": "^1.25.6",
    "prosemirror-state": "^1.4.4",
    "prosemirror-transform": "^1.12.0",
    "prosemirror-view": "^1.41.8",
    "resend": "^6.12.3",
    "socket.io": "^4.8.3",
    "stripe": "^22.1.1",
    "telegram": "^2.26.22",
    "ws": "^8.18.0",
    "y-prosemirror": "^1.3.7",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.30",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^22.10.5",
    "@types/supertest": "^6.0.2",
    "@types/ws": "^8.5.13",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^9.18.0",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.4.2",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.8"
  }
}
