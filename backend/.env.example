# ─── Runtime ──────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
LOG_LEVEL=debug

# ─── Database ─────────────────────────────────────────────────
# Matches docker-compose.yml defaults; for Atlas, paste the SRV string here.
MONGODB_URI=mongodb://wiscord:wiscord@localhost:27017/wiscord?authSource=admin

# ─── Auth ─────────────────────────────────────────────────────
# 32-byte (or longer) random string. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-me-with-a-real-secret
# How long a session cookie is valid (seconds). Default 30 days.
SESSION_TTL_SECONDS=2592000

# ─── Frontend origin (CORS) ───────────────────────────────────
FRONTEND_ORIGIN=http://localhost:5173

# ─── AI (Google Gemini API) ───────────────────────────────────
# Create a key at https://aistudio.google.com/app/apikey. Free-tier
# limits apply per-model. Leave blank in dev to make the /ai/ask
# endpoint return a friendly 503 without breaking the rest of the
# app.
GOOGLE_API_KEY=
# Default: gemini-2.0-flash (reliable tool-calling + chat in one
# call). Swap to gemini-2.5-flash for stronger reasoning at higher
# cost, or gemini-2.0-flash-lite for tighter free-tier limits.
GEMINI_MODEL=gemini-2.0-flash

# ─── Voice (LiveKit) ──────────────────────────────────────────
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ─── Storage (Telegram MTProto, free) ─────────────────────────
# Uses a Telegram USER account (not a bot) so videos / gifs aren't capped by
# the Bot API's 20 MB getFile limit. See docs/storage-telegram.md.
#   1. Sign in at https://my.telegram.org/apps and create an app → API ID + Hash
#   2. Paste them below
#   3. Run `npm run storage:login` once → it prints TELEGRAM_SESSION_STRING
#   4. Paste the session string below
STORAGE_DRIVER=telegram
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_STRING=
# Hard ceiling per single upload (bytes). Default 50 MB. Bump cautiously —
# Express buffers the whole request in memory before passing it to gramjs.
STORAGE_MAX_BYTES=52428800

# ─── Storage (S3-compatible, unused — kept for forward compat) ─
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL=

# ─── Billing (Stripe) ─────────────────────────────────────────
# All three are optional in dev — the /billing routes return a 503
# `billing_not_configured` when STRIPE_SECRET_KEY is empty so the rest of
# the app keeps working without a Stripe account.
#
# Local webhook setup:
#   stripe login
#   stripe listen --forward-to localhost:3001/billing/webhook
# That command prints `whsec_…` — paste into STRIPE_WEBHOOK_SECRET.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Stripe Price ID for the Pro monthly plan (price_xxx). Required to enable
# the Upgrade flow; the rest of the billing surface still works without it.
STRIPE_PRICE_PRO_MONTHLY=

# ─── Music integrations ───────────────────────────────────────
# Spotify: https://developer.spotify.com/dashboard → create app
#   Redirect URI in the Spotify dashboard MUST match SPOTIFY_REDIRECT_URI
#   exactly. NOTE: Spotify rejects `localhost` in redirect URIs — use the
#   loopback IP literal `127.0.0.1` for dev (or full HTTPS in prod).
#   Dev:  http://127.0.0.1:3001/integrations/spotify/callback
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3001/integrations/spotify/callback

# Google (covers YouTube Music — we OAuth into the user's Google account
# and read their music data via the YouTube Data API v3).
#   1. https://console.cloud.google.com/ → new project
#   2. APIs & Services → Library → enable "YouTube Data API v3"
#   3. APIs & Services → Credentials → Create OAuth client (Web app)
#   4. Add redirect URI matching GOOGLE_REDIRECT_URI below
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/integrations/google/callback

# 32-byte hex string (64 chars). Encrypts integration tokens at rest.
# Generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If unset in dev, the module derives a key from JWT_SECRET via HKDF so
# sign-up works without extra setup. ALWAYS set this explicitly in prod —
# rotating JWT_SECRET would otherwise nuke every stored integration token.
INTEGRATION_ENCRYPTION_KEY=
