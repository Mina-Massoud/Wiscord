# ─── Runtime ──────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
LOG_LEVEL=debug

# ─── Database ─────────────────────────────────────────────────
# Matches docker-compose.yml defaults; for Atlas, paste the SRV string here.
MONGODB_URI=mongodb://wiscord:wiscord@localhost:27017/wiscord?authSource=admin

# ─── Auth ─────────────────────────────────────────────────────
# 32-byte (or longer) random string. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-me-with-a-real-secret
# How long a session cookie is valid (seconds). Default 30 days.
SESSION_TTL_SECONDS=2592000
# How long a magic-link token is valid (seconds). Default 15 minutes.
MAGIC_LINK_TTL_SECONDS=900

# ─── Frontend origin (CORS + redirect target after magic link) ─
FRONTEND_ORIGIN=http://localhost:5173

# ─── Email (Resend) ───────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_FROM_NAME=Wiscord

# ─── AI (Anthropic) ───────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ─── Voice (LiveKit) ──────────────────────────────────────────
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ─── Storage (R2/S3) ──────────────────────────────────────────
# Leave empty to use local-disk storage at backend/uploads/.
STORAGE_DRIVER=local
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL=
