# ─── Local Edge Function dev only ─────────────────────────────────
# Used by `supabase functions serve --env-file ./supabase/functions/.env`
# Copy this file to `.env` in the same folder and fill in real values.
# `.env` is gitignored. Never commit real keys.
#
# In production (deployed functions), these come from `supabase secrets set`,
# not from this file. SUPABASE_URL / SUPABASE_ANON_KEY / SUPABASE_SERVICE_ROLE_KEY
# are auto-injected by Supabase at runtime — don't set them here.

# Anthropic — required by ai-ask
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# LiveKit — required by livekit-token (defer until voice channels are wired up)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=API_REPLACE_ME
LIVEKIT_API_SECRET=REPLACE_ME
